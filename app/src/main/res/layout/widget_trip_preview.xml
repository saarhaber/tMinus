<?xml version="1.0" encoding="utf-8"?>
<!-- Fake preview shown in the widget picker (long-press → widgets). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/fill2">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@drawable/widget_preview_route_pill"
        android:text="@string/widget_preview_route_label"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/widget_preview_trip_summary"
        android:textColor="@color/key"
        android:textSize="15sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="@string/widget_preview_times"
        android:textColor="@color/deemphasized"
        android:textSize="13sp" />
</LinearLayout>
