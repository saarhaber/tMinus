<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".TminusApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_foreground"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tminus">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Tminus">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Tminus" />

        <activity
            android:name="com.mbta.tid.mbta_app.android.widget.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.Tminus">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <receiver
            android:name="com.mbta.tid.mbta_app.android.widget.MBTATripWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_trip_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="androidx.glance.appwidget.GlanceAppWidget"
                android:value="com.mbta.tid.mbta_app.android.widget.MBTATripWidget" />
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/mbta_trip_widget_info" />
        </receiver>
    </application>
</manifest>
